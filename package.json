{
  "name": "@xjt/xjt-weather-mcp",
  "version": "0.1.0",
  "description": "基于高德地图天气 API 的 MCP Server",
  "type": "module",
  "bin": "./dist/server.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json",
    "test:mcp": "tsx scripts/test-mcp.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "weather",
    "quickstart"
  ],
  "author": "xjt",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
