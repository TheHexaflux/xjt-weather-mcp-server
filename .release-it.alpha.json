{
  "git": {
    "commit": true,
    "commitMessage": "chore: release v${version}",
    "tag": true,
    "tagName": "v${version}",
    "push": true,
    "pushArgs": ["--follow-tags"],
    "requireCleanWorkingDir": true,
    "requireUpstream": false,
    "requireBranch": ["alpha"]
  },
  "npm": {
    "publish": true,
    "tag": "alpha"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "prerelease": true
  },
  "hooks": {
    "before:init": ["pnpm run typecheck", "pnpm run build"]
  },
  "plugins": {
    "@release-it/keep-a-changelog": {
      "filename": "CHANGELOG.md"
    }
  }
}
